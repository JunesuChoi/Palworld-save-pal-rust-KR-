{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PalworldSavePal-KR",
  "mainBinaryName": "psp",
  "identifier": "com.palworldsavepal.kr",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev:desktop",
      "cwd": "../ui"
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui_build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Palworld save editor",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../ui_build": "ui",
      "../data": "data"
    }
  }
}
